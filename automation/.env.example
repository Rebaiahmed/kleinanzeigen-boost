PORT=3001
INTERNAL_SECRET=REPLACE_WITH_SAME_SECRET_AS_BACKEND
NODE_ENV=production
# Path to a system Chrome when Playwright's bundled Chromium isn't available
# (e.g. unsupported OS). Leave unset locally to use bundled chromium.
CHROMIUM_PATH=/usr/bin/google-chrome-stable

# Optional override for the Kleinanzeigen "my ads" URL used during repost
# automation (repost.ts). Defaults to the real URL below if unset.
MARKETPLACE_MY_ADS_URL=https://www.kleinanzeigen.de/m-meine-anzeigen.html

# ── Residential proxy (OPTIONAL — fixes the datacenter-IP block for server-side
#    reposts when the user's browser is closed). Leave UNSET to run with the
#    host's direct IP (default). Set ONE of these forms:
# PROXY_URL=http://user:pass@host:port            # or socks5://user:pass@host:port
# PROXY_SERVER=http://host:port
# PROXY_USERNAME=your-proxy-user
# PROXY_PASSWORD=your-proxy-pass
#
# Bandwidth-saving resource blocking (fonts/media + ad/analytics hosts). Auto-ON
# when a proxy is set (cuts per-GB cost). Force with: BLOCK_RESOURCES=true|false
# BLOCK_RESOURCES=true
