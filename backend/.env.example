NODE_ENV=production
PORT=3000

# JWT — generate with: openssl rand -hex 64
# Only an access token exists today (no refresh-token rotation) — expiry is
# hardcoded to 7d in auth.module.ts, not configurable via env.
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX

# Encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX

# Firebase Admin credentials are loaded from firebase-credentials.json on disk
# (see firebase.service.ts), not from env vars — place that file at the
# backend/ working directory root; it's gitignored.

# Internal services — names MUST match what the code reads
AUTOMATION_WORKER_URL=http://127.0.0.1:3001
INTERNAL_SECRET=REPLACE_WITH_32_CHAR_RANDOM   # must be identical in automation/.env

# CORS
FRONTEND_URL=https://anzeigenboost.de

# Donations
PAYPAL_DONATE_URL=https://www.paypal.com/donate/?hosted_button_id=YOUR_BUTTON_ID
KOFI_URL=https://ko-fi.com/yourusername
GITHUB_URL=https://github.com/yourusername/anzeigenboost

# AI (xAI / Grok)
AI_MODEL=grok-4.3
AI_TEMPERATURE=0.7
AI_PRICE_TEMPERATURE=0.3

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://kleinanzeigen-app.web.app

# eBay OAuth Integration
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_REDIRECT_URI=http://localhost:3000/api/ebay/callback

# OpenRouter — from openrouter.ai
OPENROUTER_API_KEY=

# Admin API — secret for /admin/* endpoints. Generate with: openssl rand -hex 24
ADMIN_API_KEY=REPLACE_WITH_RANDOM_HEX

# Monetization master switch — OFF by default (everyone unlimited, no paywalls).
# Set to true to activate plan limits + upgrade prompts when ready to charge.
MONETIZATION_ENABLED=false

# Dev-only mock login (POST /api/auth/dev-login) — skips the real Playwright
# login flow for local testing. Auto-disabled when NODE_ENV=production;
# set to false to disable explicitly in dev too. See LOCAL_DEV.md.
DEV_LOGIN_ENABLED=true
DEV_LOGIN_EMAIL=dev@example.com

# Server-side scheduler kill-switch. Set to false to STOP the cron from calling
# the automation worker (auto-repost + view tracking) — e.g. while testing the
# client-side scheduler. Manual repost still works. Default: enabled.
SCHEDULER_ENABLED=true

# AI monthly limits (optional — these are the defaults; only apply when MONETIZATION_ENABLED=true)
AI_LIMIT_FREE=15
AI_LIMIT_STARTER=500

# Feature flags — marketplace integrations (default: all OFF until ready)
ENABLE_VINTED=false
ENABLE_EBAY=false
ENABLE_FACEBOOK_MARKETPLACE=false

# Credits wallet (pay-as-you-go, Stripe one-time purchases) — OFF by default.
# Independent of MONETIZATION_ENABLED (see above); safe to deploy this code
# with the flag off before enabling. See backend/src/config/feature-flags.ts.
ENABLE_CREDITS=false

# ── Stripe (shared secret/webhook key — used by BOTH the credits wallet above
# AND billing subscriptions below; only active when BILLING_ENABLED=true for
# subscriptions, or ENABLE_CREDITS=true for the wallet) ──
# Billing endpoints return 503 billing_disabled until all of these are present.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
# Where Stripe redirects after checkout / portal (use your prod dashboard URL in prod)
BILLING_SUCCESS_URL=http://localhost:5173/einstellungen?checkout=success
BILLING_CANCEL_URL=http://localhost:5173/einstellungen?checkout=cancel

# EN/DE i18n toggle — default ON.
FEATURE_I18N_ENABLED=true

# Cross-Posting section (Vinted/eBay) in the AI ad-editing flow — default OFF.
# Not a validated feature yet.
FEATURE_CROSSPOSTING_ENABLED=false

