VITE_API_URL=http://localhost:3000
VITE_APP_NAME=AnzeigenBoost
VITE_APP_VERSION=1.0.0

# Optional — overrides the default Buy Me a Coffee link in the support section
VITE_BUYMEACOFFEE_URL=https://buymeacoffee.com/ahmedbouhmy

# Dev-only: number of synthetic ads the "Mit Test-Account einloggen" button
# seeds via localStorage.ab_mock_ads. Stripped from production builds.
VITE_DEV_MOCK_ADS_COUNT=24

# AI-generated reply templates — on by default. Set to "false" to disable.
VITE_FEATURE_AI_TEMPLATES=true
